# =============================================================================
# StudioZero .gitignore
# =============================================================================

# macOS
.DS_Store
**/.DS_Store

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
**/*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
.mypy_cache/
.python-version
.ipynb_checkpoints/

# Virtual Environments
.env
.env.local
.env.*.local
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
env.yaml

# -----------------------------------------------------------------------------
# IDEs & Tools
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.claude/
.gemini/

# -----------------------------------------------------------------------------
# Project - Generated Content
# -----------------------------------------------------------------------------
# Pipeline outputs (temp files, final videos)
output/

# Downloaded/generated assets (stock videos, TTS audio)
# We ignore the assets directory but explicitly track music and basevideos
assets/*
!assets/music/
!assets/basevideos/

# Log files
logs/
**/*.log

# Whisper models (downloaded on first run)
models/

# Pipeline cache files
pipeline_cache.json

# -----------------------------------------------------------------------------
# Project - Sensitive Files
# -----------------------------------------------------------------------------
# Google Cloud service account credentials
creds/

# SQLite local database (tracking removed)
sqlite_mcp_server.db
